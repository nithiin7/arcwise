ANTHROPIC_API_KEY=your_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
DATABASE_URL=postgresql+asyncpg://arcwise:arcwise@localhost:5432/arcwise
USE_REDIS=false
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# Auth
AUTHENTICATION_REQUIRED=true
JWT_SECRET=change-me-to-a-random-secret
FRONTEND_URL=http://localhost:3000

# OAuth (optional — leave blank to disable each provider)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP for reset-password emails (optional — if blank, token is logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@arcwise.app
